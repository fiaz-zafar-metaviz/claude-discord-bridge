# ===== Required =====

# Discord bot token (Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=paste_your_bot_token_here

# Your Discord User ID (right-click your name -> Copy User ID)
# Only this user's messages will be executed (security guard)
ALLOWED_USER_ID=paste_your_user_id_here

# Channel ID where bot listens (right-click channel -> Copy Channel ID)
# Use a private channel for safety
ALLOWED_CHANNEL_ID=paste_channel_id_here

# Path to YOUR project root (Claude Code will operate here)
# Example Windows: C:/Users/you/projects/my-app
# Example Mac/Linux: /home/you/projects/my-app
CLAUDE_PROJECT_DIR=paste_absolute_path_to_your_project

# ===== Optional =====

# Permission mode: bypassPermissions = all tools auto-approved (full access, recommended for headless)
# Alternatives: acceptEdits, default, plan
CLAUDE_PERMISSION_MODE=bypassPermissions

# Auto-model selection:
#   - Default model: short/casual messages -> fast cheap model
#   - Heavy model: long messages (>280 chars) or prompts containing heavy keywords
#     (refactor, debug, fix bug, implement, design, security, audit, optimize, etc.)
# Override per-message: prefix '!h ' (haiku), '!s ' (sonnet), '!o ' (opus)
CLAUDE_DEFAULT_MODEL=haiku
CLAUDE_HEAVY_MODEL=sonnet

# Voice message transcription (faster-whisper, local STT, runs offline after first model download)
# Sizes: tiny (75MB, fast), base (142MB, balanced), small (466MB, better Hinglish/accents),
#        medium (1.4GB), large-v3 (2.9GB best)
# First voice message auto-downloads the model to ~/.cache/huggingface/
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8